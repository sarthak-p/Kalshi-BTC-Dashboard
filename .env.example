# ── Kalshi ───────────────────────────────────────────────────────────────────
# Required: "demo" or "prod"
KALSHI_ENV=demo

# Your Kalshi API key ID (from the Kalshi dashboard → API keys)
KALSHI_API_KEY_ID=your-kalshi-api-key-id

# RSA private key — base64-encode the PEM file:
#   openssl genrsa 2048 | base64 | tr -d '\n'
# Then upload the PUBLIC key to the Kalshi dashboard.
KALSHI_PRIVATE_KEY_B64=base64-encoded-private-key

# Series ticker for the BTC 15-min contract (used for auto-discovery).
BTC_SERIES_TICKER=KXBTCD

# ── Execution ─────────────────────────────────────────────────────────────────
# Keep paper until you're confident in live performance.
TRADING_MODE=paper
# Required verbatim for TRADING_MODE=live:
# LIVE_TRADING_ACK=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS
LIVE_TRADING_ACK=
# Target contracts per live signal (actual count floored by budget / price)
LIVE_UNIT_SIZE=10
# Max USD cost per live order (must be <= 25.00)
LIVE_MAX_ORDER_COST_USD=5.00
# Minimum seconds between live order attempts
LIVE_ORDER_COOLDOWN_S=10.0
# Allow bot to start alongside existing open Kalshi positions
LIVE_ALLOW_EXISTING_POSITIONS=false

# ── Strategy ──────────────────────────────────────────────────────────────────
# Monitor phase: only enter when this many seconds or fewer remain (last ~8 min)
MAX_ENTRY_WINDOW_S=480.0
# Stop taking new entries this many seconds before resolution
MIN_ENTRY_WINDOW_S=120.0
# Buy the probable winner only when it's priced in this range
MIN_ENTRY_PRICE_CENTS=60.0
MAX_ENTRY_PRICE_CENTS=85.0
# Minimum BTC move (USD) from window open to confirm a direction
MOMENTUM_ENTRY_USD=30.0
# Take profit / stop loss (cents)
TAKE_PROFIT_CENTS=20.0
STOP_LOSS_CENTS=12.0
# Hard close all positions this many seconds before resolution
FORCE_EXIT_TAU_S=90.0
# Minimum confidence score to act on a signal (0–1)
CONFIDENCE_THRESHOLD=0.45
# Minimum seconds between consecutive signals
SIGNAL_DEBOUNCE_S=2.0

# ── "Away from the line" filters ─────────────────────────────────────────────
# Max times Kalshi mid may cross 50¢ during monitoring (too many = still choppy)
MAX_LINE_CROSSINGS=2
# Min fraction of recent steps where price moved further from 50¢ (0.6 = 60%)
MIN_DIRECTION_CONSISTENCY=0.6
# Max ¢ range in Kalshi mid over last 60s (above this = too erratic to enter)
KALSHI_MID_MAX_RANGE_CENTS=22.0

# ── Pre-window technicals (Coinbase Exchange, free, no auth) ─────────────────
BINANCE_SYMBOL=BTC-USD
BINANCE_KLINES_INTERVAL=60
# Block entries when RSI/BB bias contradicts the trade direction
BIAS_GATE_ENABLED=true

# ── One-and-done ──────────────────────────────────────────────────────────────
# Sit out the rest of the window after a winning trade
ONE_AND_DONE=true

# ── Risk ──────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_POSITIONS=1
DAILY_LOSS_LIMIT_USD=5.0
MAX_POSITION_SIZE_USD=20.0
MIN_OPEN_INTEREST=500
NEW_WINDOW_SETTLE_S=15.0

# ── Paper trading ─────────────────────────────────────────────────────────────
STARTING_BALANCE=1000.0

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
