# ── Kalshi (required) ─────────────────────────────────────────────────────────
KALSHI_ENV=demo                        # "demo" or "prod"
KALSHI_API_KEY_ID=your-kalshi-api-key-id
# RSA private key — base64-encode the PEM:
#   openssl genrsa 2048 | base64 | tr -d '\n'
# Upload the PUBLIC key to the Kalshi dashboard.
KALSHI_PRIVATE_KEY_B64=base64-encoded-private-key
BTC_SERIES_TICKER=KXBTCD              # Series ticker for contract auto-discovery

# ── GBM model ─────────────────────────────────────────────────────────────────
BTC_SIGMA=0.80                        # Fallback annualized vol when Deribit DVOL unavailable

# ── Entry window ──────────────────────────────────────────────────────────────
MAX_ENTRY_WINDOW_S=480.0              # Entry window opens at the 8:00 mark
MIN_ENTRY_WINDOW_S=120.0              # Entry window closes at the 2:00 mark

# ── Paper bankroll ────────────────────────────────────────────────────────────
BANKROLL=250.00
# PAPER_BANKROLL_RESET=0             # Set to a positive value to reset balance on next startup

# ── Signal thresholds ─────────────────────────────────────────────────────────
MOMENTUM_ENTRY_USD=20.0              # Min BTC move from strike shown as bullish/bearish (informational)
BTC_SLOPE_SIGNAL_THRESHOLD=0.30      # Min |slope| $/s for slope to drive a lock (~$18/min)
MOMENTUM_THRESHOLD_USD=150.0         # BTC move in 10 s that triggers a 30-s velocity pause

# ── Pre-window technicals ─────────────────────────────────────────────────────
BINANCE_SYMBOL=BTC-USD
BINANCE_KLINES_INTERVAL=60           # Candle interval in seconds for RSI/BB/ADX
MIN_ADX_THRESHOLD=15.0               # ADX below this suppresses all RSI/BB signals (no trend)

# ── Informational feed thresholds (display only) ──────────────────────────────
FUTURES_TAKER_RATIO_HIGH=1.15        # Taker ratio above this flags long-heavy
FUTURES_TAKER_RATIO_LOW=0.85         # Taker ratio below this flags short-heavy
BINANCE_DEPTH_IMBALANCE_THRESHOLD=0.15  # Depth imbalance magnitude for signal display
LIQ_VETO_THRESHOLD_USD=500000        # 2-min rolling liquidation USD for signal display

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
