# ── Kalshi ───────────────────────────────────────────────────────────────────
# Required: "demo" or "prod"
KALSHI_ENV=prod

# Your Kalshi API key ID (from the Kalshi dashboard → API keys)
KALSHI_API_KEY_ID=your-kalshi-api-key-id

# RSA private key — base64-encode the PEM file:
#   openssl genrsa 2048 | base64 | tr -d '\n'
# Then upload the PUBLIC key to the Kalshi dashboard.
KALSHI_PRIVATE_KEY_B64=base64-encoded-private-key

# Series ticker for the BTC 15-min contract (used for auto-discovery).
BTC_SERIES_TICKER=KXBTC15M

# Override these only if Kalshi changes their endpoint URLs.
KALSHI_REST_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_BASE=wss://api.elections.kalshi.com/trade-api/ws/v2

# ── Strategy ─────────────────────────────────────────────────────────────────
# Fallback annualised BTC vol for fair-value model (used until enough price
# history accumulates for the rolling realized vol estimator).
BTC_SIGMA=0.80
# Fire a signal when |fair_value - kalshi_mid| / 100 exceeds this fraction
SIGNAL_THRESHOLD=0.07
# Minimum signal confidence score to act (0-1)
CONFIDENCE_THRESHOLD=0.55
# Minimum seconds between consecutive signals (debounce)
SIGNAL_DEBOUNCE_S=10.0
# Only enter when this many seconds remain in the window (blocks last 4 min)
MIN_ENTRY_WINDOW_S=240.0
# Only enter when the contract side costs between these prices (scalp zone)
MIN_ENTRY_PRICE_CENTS=30.0
MAX_ENTRY_PRICE_CENTS=65.0
# Take profit when position value rises by this fraction above entry (0.15 = 15%)
TAKE_PROFIT_PCT=0.15
# Stop loss when position value drops to this fraction of entry (0.45 = 45%)
STOP_LOSS_PCT=0.45
# Seconds to block all signals after a new market is discovered (feed stabilisation)
NEW_WINDOW_SETTLE_S=15.0
# Block signals when market open interest is below this contract count
MIN_OPEN_INTEREST=500

# ── Momentum / drift guards ───────────────────────────────────────────────────
# BTC USD move over 30s to declare a momentum trend
MOMENTUM_THRESHOLD_USD=150.0
# Max fraction BTC can drift against your direction before blocking entries
MAX_ADVERSE_DRIFT_PCT=0.002
# When YES ask >= this cents, momentum filter is bypassed (spike fade mode)
FADE_EXTREME_CENTS=72.0

# ── Risk ─────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_USD=5.0

# ── Paper trading ─────────────────────────────────────────────────────────────
STARTING_BALANCE=1000.0

# ── Execution ─────────────────────────────────────────────────────────────────
# Keep paper unless you intentionally want to place real Kalshi orders.
TRADING_MODE=paper
# Required verbatim for TRADING_MODE=live:
# LIVE_TRADING_ACK=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS
LIVE_TRADING_ACK=
# Target contracts per signal (actual count is floored by budget / price)
LIVE_UNIT_SIZE=5
# Max USD cost per live order (must be <= 25.00)
LIVE_MAX_ORDER_COST_USD=5.00
# Minimum seconds between live order attempts
LIVE_ORDER_COOLDOWN_S=10.0
# Set to true only if you want to run alongside existing Kalshi positions
LIVE_ALLOW_EXISTING_POSITIONS=false

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
